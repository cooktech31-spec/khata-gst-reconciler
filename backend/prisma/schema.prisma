// =====================================================================
// PRISMA SCHEMA — GST Reconciler Database
// =====================================================================
// Yeh file teen tables define karti hai:
//   1. Company        -> tera business / GSTIN profile (multi-business ready)
//   2. ReconciliationBatch -> har mahine ka "ek run" — jab teen platforms ke
//                              file upload karke reconcile karte ho
//   3. LineItem        -> har order/invoice ki normalized row (Meesho/Amazon/
//                          Flipkart se aane ke baad common format mein)
//
// Production mein PostgreSQL use karna hai (Supabase free tier ya Render).
// Local testing ke liye SQLite bhi chala sakte ho (datasource neeche).
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // local testing ke liye "sqlite" kar sakte ho
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(uuid())
  legalName String
  gstin     String   @unique
  homeState String // GSTIN se nikla state — intra vs inter-state tax decide karne ke liye
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batches ReconciliationBatch[]
}

model ReconciliationBatch {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])

  periodMonth Int // 1-12
  periodYear  Int

  status String @default("processing") // processing | completed | failed
  errorMessage String?

  // Quick-access summary numbers (denormalized for fast dashboard loading)
  totalOrders        Int     @default(0)
  totalTaxableValue   Decimal @default(0) @db.Decimal(14, 2)
  totalTaxCollected   Decimal @default(0) @db.Decimal(14, 2)
  tcsExpected         Decimal @default(0) @db.Decimal(14, 2)
  tcsReportedByPlatforms Decimal @default(0) @db.Decimal(14, 2)
  mismatchCount       Int     @default(0)

  aiInsightHinglish String? @db.Text // Claude se generated plain-language summary

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems LineItem[]

  @@unique([companyId, periodMonth, periodYear])
}

model LineItem {
  id      String              @id @default(uuid())
  batchId String
  batch   ReconciliationBatch @relation(fields: [batchId], references: [id])

  platform String // MEESHO | AMAZON | FLIPKART

  orderId       String
  invoiceNumber String?
  invoiceDate   DateTime?

  hsnCode      String?
  productName  String?

  taxableValue Decimal @db.Decimal(12, 2)
  taxRate      Decimal @db.Decimal(5, 2) // e.g. 5.00, 18.00, 40.00
  cgst         Decimal @default(0) @db.Decimal(12, 2)
  sgst         Decimal @default(0) @db.Decimal(12, 2)
  igst         Decimal @default(0) @db.Decimal(12, 2)
  tcsAmount    Decimal @default(0) @db.Decimal(12, 2)

  buyerState String?
  buyerGstin String?
  supplyType String // B2B | B2CL | B2CS  (B2CL = B2C Large, invoice value > 1L inter-state)

  orderStatus String @default("DELIVERED") // DELIVERED | RETURNED | CANCELLED

  // Flags raised by the reconciliation engine for this specific row
  flagMissingHsn    Boolean @default(false)
  flagRateMismatch  Boolean @default(false)
  flagDuplicate     Boolean @default(false)

  rawRow Json? // original row preserved for audit trail / debugging

  @@index([batchId])
  @@index([platform])
}
